# Copy to .env on the server. Do not commit the real .env file.

POSTGRES_DB=vlainter
POSTGRES_USER=vlainter
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me-redis-password

MINIO_ROOT_USER=vlainter-minio
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=vlainter-local

# Host-bound diagnostic ports. They bind to 127.0.0.1 only.
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001

# App container connection values for host-level PostgreSQL and Redis.
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/vlainter
SPRING_DATASOURCE_USERNAME=vlainter
SPRING_DATASOURCE_PASSWORD=change-me
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_SSL_ENABLED=false

# App container connection values for MinIO-compatible S3.
AWS_ACCESS_KEY_ID=vlainter-minio
AWS_SECRET_ACCESS_KEY=change-me-minio-password
AWS_S3_BUCKET=vlainter-local
S3_BUCKET_NAME=vlainter-local
AWS_REGION=ap-northeast-2
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_PATH_STYLE_ACCESS=true

# AI routing for local migration.
# Generation uses a stateless Hermes profile. Embeddings intentionally stay on Gemini API.
AI_PROVIDER=HERMES
AI_EMBEDDING_PROVIDER=GEMINI
AI_FALLBACK_TO_HEURISTIC=true
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=768
HERMES_ENDPOINT=http://host.docker.internal:8788/generate
HERMES_API_KEY=
HERMES_MODEL=hermes
HERMES_PROFILE=vlainter-stateless-llm
HERMES_TEMPERATURE=0.2
HERMES_MAX_TOKENS=2048
BEDROCK_ENABLED=false
