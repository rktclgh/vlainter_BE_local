# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vlainter
DB_USERNAME=vlainter
DB_PASSWORD=change-me
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
TZ=Asia/Seoul

# Redis / Session
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false

# JWT
JWT_ISSUER=vlainter-local
JWT_ACCESS_EXP_SECONDS=1800
JWT_REFRESH_EXP_SECONDS=1209600
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Cookie
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_ACCESS_TOKEN_NAME=vlainter_access
COOKIE_REFRESH_TOKEN_NAME=vlainter_refresh

# CORS / Redirect
REDIRECT_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,vlainter://auth/callback
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
DOCS_ENABLED=false

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback

# Mail
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# Academic public API
ACADEMYINFO_API_BASE_URL=https://api.data.go.kr
ACADEMYINFO_API_SERVICE_KEY=
ACADEMYINFO_API_UNIVERSITY_PATH=/openapi/tn_pubr_public_univ_major_api
ACADEMYINFO_API_DEPARTMENT_PATH=/openapi/tn_pubr_public_univ_major_api
ACADEMYINFO_API_SURVEY_YEAR=2024

# Storage
S3_BUCKET_NAME=
AWS_REGION=ap-northeast-2

# Security
API_KEY_ENCRYPTION_SECRET=change-me-api-key-encryption-secret

# Gemini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_CHAT_MODELS=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MAX_RPM=30

# Bedrock (optional)
BEDROCK_ENABLED=false
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_REGION=ap-northeast-2

# OCR (optional)
OCR_ENABLED=true
OCR_TESSERACT_COMMAND=tesseract
OCR_LANGUAGES=kor+eng

# PortOne (optional)
PORTONE_BASE_URL=https://api.iamport.kr
PORTONE_API_KEY=
PORTONE_API_SECRET=
PORTONE_CUSTOMER_CODE=

# Support (optional)
SUPPORT_DISCORD_WEBHOOK_URL=
